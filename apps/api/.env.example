# Copier vers .env — jamais commite (voir .gitignore)

DATABASE_URL=postgresql://ubersclap:ubersclap_dev@localhost:5433/ubersclap
REDIS_URL=redis://localhost:6380

PORT=3000

# Generer avec : node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Geocodage / itineraire.
# GEO_PROVIDER=osm  -> OpenStreetMap, gratuit, sans cle (defaut).
# GEO_PROVIDER=google -> a activer avec GOOGLE_MAPS_API_KEY quand le volume grimpe.
# GEO_PROVIDER=osm
# Nominatim exige un User-Agent identifiable avec un contact reel.
# GEO_USER_AGENT=Uber's Clap/0.1 (contact@ubersclap.dev)
# Surcharger si auto-heberge (OSRM public = pas de SLA).
# NOMINATIM_URL=https://nominatim.openstreetmap.org
# OSRM_URL=https://router.project-osrm.org

# Services externes — non utilises au MVP
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# RESEND_API_KEY=
# GOOGLE_MAPS_API_KEY=
