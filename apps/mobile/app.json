{
  "expo": {
    "name": "Uber's Clap",
    "slug": "ubersclap",
    "scheme": "ubersclap",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "dev.ubersclap.app"
    },
    "android": {
      "package": "dev.ubersclap.app",
      "adaptiveIcon": {
        "backgroundColor": "#4F46E5",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-sqlite",
      [
        "expo-contacts",
        {
          "contactsPermission": "Uber's Clap accède à vos contacts pour ajouter un passager sans ressaisir son numéro."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
