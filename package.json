{
  "name": "ubersclap",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "mobile": "pnpm --filter @ubersclap/mobile start",
    "android": "pnpm --filter @ubersclap/mobile android",
    "ios": "pnpm --filter @ubersclap/mobile ios",
    "api": "pnpm --filter @ubersclap/api dev",
    "db:migrate": "pnpm --filter @ubersclap/api db:migrate",
    "db:generate": "pnpm --filter @ubersclap/api db:generate",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20"
  }
}
