{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    // CommonJS : c'est le format que consomme l'API NestJS. Metro, lui,
    // passe par la condition d'export "react-native" et lit la source.
    "module": "CommonJS",
    "moduleResolution": "node"
  },
  "include": ["src/**/*.ts"]
}
